generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id        Int      @id @default(autoincrement())
  name      String
  location  String
  fees      Float
  rating    Float
  placement Float
  courses   Course[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id        Int      @id @default(autoincrement())
  collegeId Int
  name      String
  college   College  @relation(fields: [collegeId], references: [id])
}
